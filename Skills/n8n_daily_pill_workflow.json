        "sendBody": true,
        "contentType": "json",
        "body": "={\n  \"filterGroups\": [\n    {\n      \"filters\": [\n        { \"propertyName\": \"pipeline\", \"operator\": \"EQ\", \"value\": \"671838099\" },\n        { \"propertyName\": \"dealstage\", \"operator\": \"NOT_IN\", \"values\": [\"986053469\",\"986053470\"] },\n        { \"propertyName\": \"closedate\", \"operator\": \"LT\", \"value\": \"{{ Math.floor(Date.now()) }}\" },\n        { \"propertyName\": \"amount\", \"operator\": \"GT\", \"value\": \"0\" }\n      ]\n    }\n  ],\n  \"properties\": [\"dealname\",\"dealstage\",\"amount\",\"closedate\",\"hubspot_owner_id\"],\n  \"sorts\": [{\"propertyName\": \"amount\", \"direction\": \"DESCENDING\"}],\n  \"limit\": 5\n}",
