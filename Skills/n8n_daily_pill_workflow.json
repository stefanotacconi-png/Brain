      "id": "mon-overdue-deals",
      "name": "📅 MON: Overdue Deals",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [920, 180]
    },
    {
      "parameters": {
        "jsCode": "// Owner ID to name map\nconst owners = {\n  '75722736': 'Cristina',\n  '75722777': 'Giuseppe',\n  '30727447': 'Víctor',\n  '31172513': 'Marco',\n  '30334309': 'Vincenzo',\n  '31903434': 'Bruno',\n  '30908030': 'Manuel',\n  '31012966': 'Stefano'\n};\n\nconst stageNames = {\n  '986053466': 'Discovery',\n  '986053467': 'Demo',\n  '986053468': 'Follow-up',\n  '2674750700': 'Negotiation/Trial'\n};\n\nconst zeroDealsList = $input.all().filter(i => i.json.results !== undefined)[0]?.json?.results || [];\nconst overdueDealsList = $input.all().filter(i => i.json.results !== undefined)[1]?.json?.results || [];\n\nconst formatEuro = (v) => v ? `€${Number(v).toLocaleString('it-IT')}` : '€0';\nconst formatDate = (d) => d ? new Date(d).toLocaleDateString('it-IT', {day:'2-digit',month:'short'}) : 'no date';\n\nlet msg = 'hey team, oggi tips & focus 🧹\\n\\n*📊 Lunedì — Data Hygiene Day*\\nPipeline pulita = forecast preciso = target centrato.\\n';\n\nif (zeroDealsList.length) {\n  msg += '\\n*🚨 Deals avanzati con €0 — update ASAP:*\\n';\n  for (const d of zeroDealsList.slice(0,4)) {\n    const p = d.properties;\n    const owner = owners[p.hubspot_owner_id] || 'N/A';\n    const stage = stageNames[p.dealstage] || p.dealstage;\n    msg += `• *${p.dealname}* (${stage}) → ${owner}, aggiungi valore oggi\\n`;\n  }\n}\n\nif (overdueDealsList.length) {\n  msg += '\\n*📅 Close date scadute — aggiorna o chiudi:*\\n';\n  for (const d of overdueDealsList.slice(0,5)) {\n    const p = d.properties;\n    const owner = owners[p.hubspot_owner_id] || 'N/A';\n    msg += `• *${p.dealname}* ${formatEuro(p.amount)} (scaduto ${formatDate(p.closedate)}) → ${owner}\\n`;\n  }\n}\n\nmsg += `\\n💡 *Perché conta:* ${$input.all()[0]?.json?.total || 0} deals con date scadute + almeno ${zeroDealsList.length} deals avanzati a €0 = forecast sbagliato. 5 min a deal e sistemiamo tutto 💪`;\n\nreturn [{ json: { text: msg } }];"
      },
      "id": "mon-build-msg",
      "name": "💬 MON: Build Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1160, 130]
    },

