      "id": "schedule-trigger",
      "name": "⏰ Daily 10am Mon–Fri",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "jsCode": "// Get day of week: 1=Mon, 2=Tue, 3=Wed, 4=Thu, 5=Fri\nconst now = new Date(new Date().toLocaleString('en-US', { timeZone: 'Europe/Rome' }));\nconst dayOfWeek = now.getDay(); // 0=Sun, 1=Mon ... 5=Fri\nreturn [{ json: { dayOfWeek } }];"
      },
      "id": "get-day",
      "name": "📅 Get Day of Week",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "rules": {
          "rules": [
            { "outputKey": "monday", "conditions": { "conditions": [{ "id": "mon", "leftValue": "={{ $json.dayOfWeek }}", "rightValue": 1, "operator": { "type": "number", "operation": "equals" } }], "combinator": "and" }, "renameOutput": true },
            { "outputKey": "tuesday", "conditions": { "conditions": [{ "id": "tue", "leftValue": "={{ $json.dayOfWeek }}", "rightValue": 2, "operator": { "type": "number", "operation": "equals" } }], "combinator": "and" }, "renameOutput": true },
            { "outputKey": "wednesday", "conditions": { "conditions": [{ "id": "wed", "leftValue": "={{ $json.dayOfWeek }}", "rightValue": 3, "operator": { "type": "number", "operation": "equals" } }], "combinator": "and" }, "renameOutput": true },
            { "outputKey": "thursday", "conditions": { "conditions": [{ "id": "thu", "leftValue": "={{ $json.dayOfWeek }}", "rightValue": 4, "operator": { "type": "number", "operation": "equals" } }], "combinator": "and" }, "renameOutput": true },
            { "outputKey": "friday", "conditions": { "conditions": [{ "id": "fri", "leftValue": "={{ $json.dayOfWeek }}", "rightValue": 5, "operator": { "type": "number", "operation": "equals" } }], "combinator": "and" }, "renameOutput": true }
          ]
        },
        "options": {}
      },
      "id": "day-switch",
      "name": "📋 Route by Day",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [680, 300]
    },

    {
